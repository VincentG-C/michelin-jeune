generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                    Int      @id @default(autoincrement())
  email                 String   @unique
  password              String
  username              String   @unique
  phone                 String?
  bio                   String?
  avatarUrl             String?  @map("avatar_url")
  preferredFilters      String[] @default([]) @map("preferred_filters")
  favoriteRestaurantIds Int[]    @default([]) @map("favorite_restaurant_ids")
  createdAt             DateTime @default(now()) @map("created_at")

  checkins         Checkin[]
  userTampons      UserTampon[]
  userHistoires    UserHistoire[]
  userRecompenses UserRecompense[]

  @@map("users")
}

enum MichelinType {
  etoile_1
  etoile_2
  etoile_3
  bib
  hotel
}

enum Budget {
  low
  medium
  high
}

model Restaurant {
  id           Int          @id @default(autoincrement())
  name         String
  address      String
  lat          Float
  lng          Float
  michelinType MichelinType @map("michelin_type")
  stars        Int          @default(0)
  budget       Budget       @default(medium)
  cuisine      String?
  ambiance     String?
  photoUrl     String?      @map("photo_url")
  description  String?
  isEco        Boolean      @default(false) @map("is_eco")
  isHiddenGem  Boolean      @default(false) @map("is_hidden_gem")
  isVisual     Boolean      @default(false) @map("is_visual")

  checkins Checkin[]
  tampon   Tampon?
  histoires Histoire[]

  @@map("restaurants")
}

model Checkin {
  id           Int      @id @default(autoincrement())
  userId       Int      @map("user_id")
  restaurantId Int      @map("restaurant_id")
  checkedAt    DateTime @default(now()) @map("checked_at")

  user       User       @relation(fields: [userId], references: [id])
  restaurant Restaurant @relation(fields: [restaurantId], references: [id])

  @@map("checkins")
}

model Tampon {
  id           Int      @id @default(autoincrement())
  restaurantId Int      @unique @map("restaurant_id")
  imageUrl     String?  @map("image_url")
  color        String

  restaurant Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  userTampons UserTampon[]

  @@map("tampons")
}

model UserTampon {
  id         Int      @id @default(autoincrement())
  userId     Int      @map("user_id")
  tamponId   Int      @map("tampon_id")
  pageNumber Int      @map("page_number")
  positionX  Float    @map("position_x")
  positionY  Float    @map("position_y")
  collectedAt DateTime @default(now()) @map("collected_at")

  user   User   @relation(fields: [userId], references: [id])
  tampon Tampon @relation(fields: [tamponId], references: [id])

  @@index([userId, collectedAt])
  @@map("user_tampons")
}

model Chapitre {
  id          Int    @id @default(autoincrement())
  titre       String
  ordre       Int    @unique
  recompenseId Int?  @unique @map("recompense_id")

  histoires   Histoire[]
  recompense  Recompense?

  @@map("chapitres")
}

model Recompense {
  id          Int      @id @default(autoincrement())
  chapitreId  Int      @unique @map("chapitre_id")
  titre       String
  description String

  chapitre        Chapitre       @relation(fields: [chapitreId], references: [id], onDelete: Cascade)

  userRecompenses UserRecompense[]

  @@map("recompenses")
}

model UserRecompense {
  id           Int       @id @default(autoincrement())
  userId       Int       @map("user_id")
  recompenseId Int       @map("recompense_id")
  unlockedAt   DateTime  @default(now()) @map("unlocked_at")
  isUsed       Boolean   @default(false) @map("is_used")

  user       User      @relation(fields: [userId], references: [id])
  recompense Recompense @relation(fields: [recompenseId], references: [id])

  @@unique([userId, recompenseId])
  @@map("user_recompenses")
}

model Histoire {
  id            Int     @id @default(autoincrement())
  chapitreId    Int     @map("chapitre_id")
  restaurantId  Int     @unique @map("restaurant_id")
  titre         String
  contenu       String
  imageCarteUrl String? @map("image_carte_url")
  ordre         Int

  chapitre      Chapitre     @relation(fields: [chapitreId], references: [id], onDelete: Cascade)
  restaurant    Restaurant   @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  userHistoires UserHistoire[]

  @@unique([chapitreId, ordre])

  @@map("histoires")
}

model UserHistoire {
  id         Int      @id @default(autoincrement())
  userId     Int      @map("user_id")
  histoireId Int      @map("histoire_id")
  unlockedAt DateTime @default(now()) @map("unlocked_at")

  user     User     @relation(fields: [userId], references: [id])
  histoire Histoire @relation(fields: [histoireId], references: [id])

  @@unique([userId, histoireId])
  @@map("user_histoires")
}
